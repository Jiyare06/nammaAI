# ── Server ──
FRONTEND_URL=http://localhost:3000

# ── Advisory generation (Gemini Flash — free tier, no billing needed) ──
GEMINI_API_KEY=your-gemini-key-here

# ── Translation (Sarvam AI — optional, falls back to MyMemory free API) ──
SARVAM_API_KEY=your-sarvam-key-here

# ── Photo upload (Cloudinary — free tier, 25 GB) ──
# Get these from https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Database & Auth ──
DATABASE_URL=postgresql://namma:namma@localhost:5432/namma_traffic
JWT_SECRET_KEY=replace-this-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
